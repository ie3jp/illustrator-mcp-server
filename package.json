{
  "name": "illustrator-mcp-server",
  "version": "1.2.4",
  "mcpName": "io.github.ie3jp/illustrator-mcp-server",
  "description": "MCP server for reading, manipulating, and exporting Adobe Illustrator design data",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "illustrator-mcp-server": "dist/index.js"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "prepublishOnly": "vp pack"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "illustrator",
    "adobe",
    "extendscript",
    "jsx",
    "design",
    "svg"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ie3jp/illustrator-mcp-server.git"
  },
  "homepage": "https://github.com/ie3jp/illustrator-mcp-server",
  "bugs": {
    "url": "https://github.com/ie3jp/illustrator-mcp-server/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "p-limit": "^7.3.0"
  },
  "devDependencies": {
    "@valibot/to-json-schema": "^1.3.0",
    "@voidzero-dev/vite-plus-core": "latest",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "unplugin-macros": "^0.19.1",
    "valibot": "^1.1.0",
    "vite": "^8.0.0",
    "vite-plus": "^0.1.14",
    "vitest": "^4.1.1"
  }
}
