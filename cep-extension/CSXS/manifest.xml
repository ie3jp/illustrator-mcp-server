<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0"
  ExtensionBundleId="com.github.ie3jp.illustrator-mcp-bridge"
  ExtensionBundleVersion="1.0.0"
  ExtensionBundleName="Illustrator MCP Bridge">

  <ExtensionList>
    <Extension Id="com.github.ie3jp.illustrator-mcp-bridge.panel" Version="1.0.0"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <!-- Illustrator CC 2024 (v28) 以降 -->
      <Host Name="ILST" Version="[28.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="11.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.github.ie3jp.illustrator-mcp-bridge.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
        </Resources>
        <Lifecycle>
          <!-- パネルを開いた状態を維持 -->
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Illustrator MCP Bridge</Menu>
          <Geometry>
            <PreferredSize>
              <Height>56</Height>
              <Width>220</Width>
            </PreferredSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
